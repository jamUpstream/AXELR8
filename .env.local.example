# Supabase — Phase 2 CMS
# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings → API).

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only — NEVER expose to the client or commit a real value.
# Used by /lib/supabase-admin.ts and scripts/seed.ts for privileged writes.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Lead notifications. If RESEND_API_KEY is unset, email is skipped silently
# (the contact form still saves leads). Get a key at https://resend.com.
RESEND_API_KEY=

# The "from" address. Until you verify your own domain in Resend, leave this as
# the shared sender below — note: the shared sender can ONLY deliver to the
# email that owns your Resend account (so admin notifications to yourself work,
# but auto-replies to leads will not deliver until you set a verified domain).
# Once verified, set e.g. EMAIL_FROM="AXLER8 <hello@yourdomain.com>".
EMAIL_FROM="AXLER8 <onboarding@resend.dev>"

# ── Calendly ─────────────────────────────────────────────────────────────────
# Your scheduling link, e.g. https://calendly.com/yourname/30min. Used by the
# "Schedule via Calendly" button in the lead composer. Public (the widget runs
# in the browser). If unset, the schedule button is hidden.
NEXT_PUBLIC_CALENDLY_URL=
